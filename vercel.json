{
  "framework": "nextjs",
  "buildCommand": "cd frontend && next build",
  "outputDirectory": "frontend/.next",
  "installCommand": "cd frontend && npm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.listingjet.ai/:path*"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "/api"
  }
}
