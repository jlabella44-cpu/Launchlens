# App
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://launchlens:password@localhost:5432/launchlens
DATABASE_URL_SYNC=postgresql://launchlens:password@localhost:5432/launchlens

# Auth
JWT_SECRET=changeme-32-chars-minimum-secret-xx
JWT_ALGORITHM=HS256

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=launchlens-main

# Redis
REDIS_URL=redis://localhost:6379/0

# S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=launchlens-dev

# External APIs
GOOGLE_VISION_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CANVA_API_KEY=

# ClamAV
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=  # Empty = disabled; docker: http://jaeger:4317

# RESO MLS
RESO_API_URL=
RESO_API_KEY=

# Video (Kling AI)
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# Email / Notifications
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@launchlens.com

# Monitoring
SENTRY_DSN=
GIT_SHA=

# Feature flags
SHADOW_REVIEW_ENABLED=true
SHADOW_REVIEW_MAX_LISTINGS=100

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...
