# App
APP_ENV=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://launchlens:password@localhost:5432/launchlens
DATABASE_URL_SYNC=postgresql://launchlens:password@localhost:5432/launchlens

# Auth
JWT_SECRET=changeme-32-chars-minimum-secret-xx
JWT_ALGORITHM=HS256

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=launchlens-main

# Redis
REDIS_URL=redis://localhost:6379/0

# S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=launchlens-dev

# External APIs
GOOGLE_VISION_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CANVA_API_KEY=

# Feature flags
SHADOW_REVIEW_ENABLED=true
SHADOW_REVIEW_MAX_LISTINGS=100
