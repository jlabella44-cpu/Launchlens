# ─────────────────────────────────────────────
# ListingJet — Environment Configuration
# Copy to .env and fill in your values.
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
# development | staging | production
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# ── Database ─────────────────────────────────
# Async URL (used by FastAPI + Temporal worker)
DATABASE_URL=postgresql+asyncpg://listingjet:password@localhost:5432/listingjet
# Sync URL (used by Alembic migrations only)
DATABASE_URL_SYNC=postgresql://listingjet:password@localhost:5432/listingjet

# ── Auth ─────────────────────────────────────
# Must be at least 32 characters; use a cryptographically random string
JWT_SECRET=changeme-32-chars-minimum-secret-xx
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=7

# ── Stripe ───────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Plan price IDs from your Stripe dashboard
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...
# v3 tier price IDs
STRIPE_PRICE_LITE=
STRIPE_PRICE_ACTIVE_AGENT=
STRIPE_PRICE_TEAM=

# ── Temporal ─────────────────────────────────
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=listingjet-main

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AWS / S3 ─────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=listingjet-dev

# ── Monitoring / Observability ───────────────
# Sentry DSN — leave blank to disable error reporting
SENTRY_DSN=
# Git commit SHA injected at deploy time (used in Sentry releases)
GIT_SHA=

# OpenTelemetry — OTLP gRPC endpoint (e.g. http://otel-collector:4317)
# Leave blank to disable tracing export; docker: http://jaeger:4317
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Feature Flags ────────────────────────────
# Shadow review: run automated checks on all approved listings
SHADOW_REVIEW_ENABLED=true
SHADOW_REVIEW_MAX_LISTINGS=100

# ── Google OAuth (Sign In With Google) ───────
GOOGLE_OAUTH_CLIENT_ID=

# ── AI Provider Keys ─────────────────────────
GOOGLE_VISION_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

QWEN_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# LLM provider selection: "anthropic" (default), "openai", "gemma"
LLM_PROVIDER=anthropic
LLM_FALLBACK_ENABLED=true
# Set to "qwen" to use Qwen 3.6 Plus for Tier 2 vision (default: openai)
VISION_PROVIDER_TIER2=openai

# Set to true to use mock providers in tests / local dev (no real API calls)
USE_MOCK_PROVIDERS=false

# ── Video Pipeline (Kling AI) ─────────────────
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_API_BASE_URL=https://api.klingai.com
# Max photos selected for video generation
VIDEO_MAX_PHOTOS=8
# Minimum quality score for a photo to be included in video
VIDEO_SCORE_FLOOR=0.65
# Duration (seconds) of each generated clip
VIDEO_CLIP_DURATION=5

# ── ClamAV (virus scanning) ───────────────────
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# ── RESO MLS ─────────────────────────────────
RESO_API_URL=
RESO_API_KEY=

# ── Canva Connect API ────────────────────────
CANVA_API_KEY=
CANVA_DEFAULT_TEMPLATE_ID=
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_REDIRECT_URI=

# ── Email / Notifications ────────────────────
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@listingjet.com
# Set to true to use AWS SES instead of SMTP
SES_ENABLED=false

# ── Property Data ────────────────────────────
PROPERTY_VERIFICATION_ENABLED=false
ATTOM_API_KEY=
WALK_SCORE_API_KEY=
