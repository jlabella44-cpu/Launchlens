# ─────────────────────────────────────────────
# LaunchLens — Environment Configuration
# Copy to .env and fill in your values.
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
# development | staging | production
APP_ENV=development
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────
# Async URL (used by FastAPI + Temporal worker)
DATABASE_URL=postgresql+asyncpg://launchlens:password@localhost:5432/launchlens
# Sync URL (used by Alembic migrations only)
DATABASE_URL_SYNC=postgresql://launchlens:password@localhost:5432/launchlens

# ── Auth ─────────────────────────────────────
# Must be at least 32 characters; use a cryptographically random string
JWT_SECRET=changeme-32-chars-minimum-secret-xx
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── Stripe ───────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from your Stripe dashboard
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── Temporal ─────────────────────────────────
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=launchlens-main

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AWS / S3 ─────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=launchlens-dev

# ── Monitoring / Observability ───────────────
# Sentry DSN — leave blank to disable error reporting
SENTRY_DSN=
# Git commit SHA injected at deploy time (used in Sentry releases)
GIT_SHA=

# OpenTelemetry — OTLP gRPC endpoint (e.g. http://otel-collector:4317)
# Leave blank to disable tracing export; docker: http://jaeger:4317
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Feature Flags ────────────────────────────
# Shadow review: run automated checks on all approved listings
SHADOW_REVIEW_ENABLED=true
SHADOW_REVIEW_MAX_LISTINGS=100

# ── AI Provider Keys ─────────────────────────
GOOGLE_VISION_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Set to true to use mock providers in tests / local dev (no real API calls)
USE_MOCK_PROVIDERS=false

# ── Video Pipeline (Kling AI) ─────────────────
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_API_BASE_URL=https://api.klingai.com
# Max photos selected for video generation
VIDEO_MAX_PHOTOS=8
# Minimum quality score for a photo to be included in video
VIDEO_SCORE_FLOOR=0.65
# Duration (seconds) of each generated clip
VIDEO_CLIP_DURATION=5

# ── ClamAV (virus scanning) ───────────────────
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# ── RESO MLS ─────────────────────────────────
RESO_API_URL=
RESO_API_KEY=

# ── Email / Notifications ────────────────────
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@launchlens.com
