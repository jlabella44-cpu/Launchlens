{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "devCommand": "next dev",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.listingjet.ai/:path*"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "/api"
  }
}
